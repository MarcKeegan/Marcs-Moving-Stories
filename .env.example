# Copy to .env and fill in real values. NEVER commit .env — it is gitignored.

# --- Build-time (Vite) ---
# Google Maps JS API key. Public in the client bundle by design, so it MUST be
# HTTP-referrer-restricted and limited to Maps/Places/Directions in Cloud Console.
GOOGLE_MAPS_API_KEY=

# Local development WITHOUT the proxy server only. Never set in a production
# build — this key would be embedded in the client bundle.
# VITE_GEMINI_API_KEY=

# Firebase web config (not secret, but environment-specific).
# In production the server injects these via window.__ENV__ instead.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# --- Server (server/server.js) — set in the deploy environment, e.g. Cloud Run secrets ---
# Server-side Gemini key. Never shipped to the browser.
GEMINI_SERVER_API_KEY=

# Server-side Google keys for the /api/directions and /api/nearby-pois proxies.
GOOGLE_DIRECTIONS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Firebase Admin credentials for verifying ID tokens.
# On Cloud Run application-default credentials are used automatically; otherwise set one of:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Comma-separated origins allowed to call the proxy cross-origin (normally empty —
# the web app is served same-origin by the server).
# ALLOWED_ORIGINS=

# DANGER: allows unauthenticated proxy access when Firebase Admin is not configured.
# Local development only.
# ALLOW_UNAUTHENTICATED=true
